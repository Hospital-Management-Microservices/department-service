# ============================================================
#   department-service — .gitignore
#   Java 17 | Spring Boot 3.x | Maven | PostgreSQL
# ============================================================

# Maven Build Output (never commit compiled code)
target/
*.jar
*.war
*.ear

# Maven Wrapper
.mvn/wrapper/maven-wrapper.jar

# Spring Boot secrets (DB passwords, API keys)
application-local.properties
application-local.yml
application-secret.properties
application-secret.yml

# IntelliJ IDEA
.idea/
.idea/workspace.xml
.idea/dataSources.local.xml
.idea/dataSources/
.idea/shelf/
.idea/tasks.xml
*.iml

# Eclipse / STS
.classpath
.project
.settings/
bin/

# VS Code
.vscode/

# Logs
logs/
*.log

# OS Files
Thumbs.db
.DS_Store

# Test reports
surefire-reports/
jacoco.exec
